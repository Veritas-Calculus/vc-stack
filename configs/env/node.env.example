# Environment variables for VC Stack Compute Node
# Copy to /etc/vc-stack/compute.env and customize

# Node Configuration
NODE_NAME=compute-node-1
NODE_ZONE=zone-1

# Agent Configuration (auto-registration)
AGENT_ENABLED=true
AGENT_MANAGEMENT_URL=http://10.31.0.3:8080
AGENT_HEARTBEAT_INTERVAL=30s

# Database Connection (Same Database)
# You can use vcctl secrets encrypt to set an encrypted password like ENC(...)
# If using ENC(...), set VC_MASTER_KEY below or in /etc/vc-stack/master.key
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=vcstack
DATABASE_USER=vcstack
DATABASE_PASSWORD=ENC(your-encrypted-password)
DATABASE_SSLMODE=disable
VC_MASTER_KEY=your_base64_master_key

# Libvirt Configuration
LIBVIRT_URI=qemu:///system
LIBVIRT_NETWORK_NAME=br-int

# ===== Storage Configuration =====
#
# Backend options: "local" or "rbd" (Ceph RBD)
#
# WARNING: "local" mode is for DEVELOPMENT AND TESTING ONLY.
# In local mode, VM disks are stored as qcow2 files on the compute node's
# local filesystem. This means:
#   - NO high availability: if the node dies, all VM data is LOST
#   - NO live migration: VMs cannot move between nodes
#   - NO shared storage: each node has its own isolated disk pool
#   - Single point of failure for all VMs on that node
#
# For PRODUCTION deployments, you MUST use "rbd" (Ceph RBD):
#   - Data is replicated across multiple OSDs (typically 3 copies)
#   - Supports live migration between compute nodes
#   - Survives individual node/disk failures
#   - Enables snapshots and clones at the storage layer
#
# To build with native Ceph SDK: GO_BUILD_TAGS=ceph make build
# Without the tag, RBD operations fall back to the `rbd` CLI tool.

# Images storage (default: local for dev, change to rbd for production)
IMAGES_BACKEND=local
IMAGES_LOCAL_PATH=/var/lib/vcstack/images
# IMAGES_BACKEND=rbd
# IMAGES_RBD_POOL=vcstack-images
# IMAGES_RBD_CLIENT=vcstack

# Volumes storage (default: local for dev, change to rbd for production)
VOLUMES_BACKEND=local
VOLUMES_LOCAL_PATH=/var/lib/vcstack/volumes
# VOLUMES_BACKEND=rbd
# VOLUMES_RBD_POOL=vcstack-volumes
# VOLUMES_RBD_CLIENT=vcstack

# Ceph/RBD global settings (required when using rbd backend)
# CEPH_CONF=/etc/ceph/ceph.conf
# CEPH_KEYRING=/etc/ceph/ceph.client.vcstack.keyring

# ===== Network Configuration (OVN/OVS) =====
#
# OVN Southbound DB address (REQUIRED for networking)
# ovn-controller on this node connects to this address to receive flow rules.
NETWORK_OVN_SB_ADDRESS=tcp:10.31.0.3:6642

# OVS integration bridge (where VM ports are attached)
OVS_INTEGRATION_BRIDGE=br-int

# Provider/external bridge (connects to physical network for VM internet access)
NETWORK_EXTERNAL_BRIDGE=br-provider

# Bridge mappings: maps OVN logical physical-network names to OVS bridges.
# Format: "physnet1:bridge1,physnet2:bridge2"
# Default: "provider:br-provider"
NETWORK_BRIDGE_MAPPINGS=provider:br-provider

# Encapsulation type: geneve (recommended, OVN default) or vxlan
NETWORK_ENCAP_TYPE=geneve

# Encapsulation IP: the IP used for tunnel endpoints between compute nodes.
# Leave empty to auto-detect (finds the IP on the interface that routes to OVN SB).
# NETWORK_ENCAP_IP=10.31.0.10

# ===== Physical Interface Configuration =====
#
# Physical interface to attach to the provider bridge.
# This enables VM traffic to reach the physical network for:
#   - Floating IP (DNAT+SNAT through OVN logical router)
#   - SNAT (VM internet access)
#   - Provider/flat networks
#
# --- Dual-NIC Setup (recommended for production) ---
# eth0 = management (kept as-is)
# eth1 = provider (attached to br-provider)
# NETWORK_PROVIDER_INTERFACE=eth1
# NETWORK_SINGLE_NIC=false
#
# --- Single-NIC Setup (small/lab deployments) ---
# eth0 serves both management and provider traffic.
# The bootstrap will migrate eth0's IP to br-provider.
# WARNING: connectivity drops briefly during migration.
# NETWORK_PROVIDER_INTERFACE=eth0
# NETWORK_SINGLE_NIC=true
NETWORK_PROVIDER_INTERFACE=
NETWORK_SINGLE_NIC=false

# Logging
LOGGING_LEVEL=info
LOGGING_FORMAT=json
LOGGING_OUTPUT=stdout

# Sentry Error Tracking
SENTRY_DSN=https://your-dsn@sentry.infra.plz.ac/project-id
SENTRY_ENVIRONMENT=production
# Optional: Override auto-detected hostname
# SENTRY_SERVER_NAME=vc-compute-01

# Monitoring
MONITORING_METRICS_ENABLED=true
MONITORING_METRICS_PORT=9091

# Resource Configuration
RESOURCES_CPU_OVERCOMMIT=2.0
RESOURCES_RAM_OVERCOMMIT=1.5
RESOURCES_RESERVED_CPU=2
RESOURCES_RESERVED_RAM_MB=4096
RESOURCES_RESERVED_DISK_GB=50
