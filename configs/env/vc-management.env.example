# Environment variables for VC Stack Management Plane
# Copy to /etc/vc-stack/management.env and customize

# ===== Database Configuration =====
# You can use vcctl secrets encrypt to set an encrypted password like ENC(...)
# If using ENC(...), set VC_MASTER_KEY below or in /etc/vc-stack/master.key
DB_HOST=localhost
DB_PORT=5432
DB_NAME=vcstack
DB_USER=vcstack
DB_PASS=ENC(your-encrypted-password)
VC_MASTER_KEY=your_base64_master_key

# ===== Server Configuration =====
# Port for the management API and web console
VC_MANAGEMENT_PORT=8080

# ===== Identity / JWT =====
# CHANGE THIS IN PRODUCTION!
JWT_SECRET=your-super-secret-jwt-key-change-in-production-please

# ===== OVN Configuration =====
# Management plane connects to OVN Northbound DB to manage logical topology.
# This is the NB address, NOT the SB address (compute nodes use SB).
NETWORK_OVN_NB_ADDRESS=tcp:127.0.0.1:6641

# Optional: also specify SB address if management needs to query chassis info
# NETWORK_OVN_SB_ADDRESS=tcp:127.0.0.1:6642

# ===== Scheduler Configuration =====
SCHEDULER_ALGORITHM=least_allocated
SCHEDULER_CPU_OVERCOMMIT=2.0
SCHEDULER_RAM_OVERCOMMIT=1.5

# ===== Logging =====
LOGGING_LEVEL=info
LOGGING_FORMAT=json
LOGGING_OUTPUT=stdout

# ===== Sentry Error Tracking =====
SENTRY_DSN=https://your-dsn@sentry.infra.plz.ac/project-id
SENTRY_ENVIRONMENT=production
# Optional: Override auto-detected hostname
# SENTRY_SERVER_NAME=vc-management-01

# ===== Monitoring =====
MONITORING_METRICS_ENABLED=true
MONITORING_METRICS_PORT=9090

# ===== CORS (for web console) =====
SECURITY_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ===== Features =====
FEATURES_MULTI_TENANCY_ENABLED=true
FEATURES_QUOTAS_ENABLED=true

# ===== Admin =====
# Default admin password (only used when seeding initial admin account)
# ADMIN_DEFAULT_PASSWORD=admin
